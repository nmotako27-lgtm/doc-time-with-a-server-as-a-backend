rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ✅ ALLOW PATIENTS TO READ/WRITE THEIR OWN PROFILE
    match /patients/{userId} {
      // Allow user to read/write if their auth UID matches the document ID
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Doctors collection
    match /doctors/{doctorId} {
      // Anyone logged in can read doctors (for selection)
      allow read: if request.auth != null;
      // Only the doctor themselves can write
      allow write: if request.auth != null && request.auth.uid == doctorId;
    }
    
    // Appointments collection
    match /appointments/{appointmentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.patientId == request.auth.uid;
      allow update: if request.auth != null && (resource.data.doctorId == request.auth.uid || resource.data.patientId == request.auth.uid);
      allow delete: if request.auth != null && resource.data.patientId == request.auth.uid;
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
